/*Ya en esta parte se agregan las funciones para llenar y visualizar  cada una de las estructuras,
 estas funciones se encargaran de pedir los datos al usuario y asignarlos a cada uno de los campos de las estructuras.*/
void add_hosp(L_HOSP *L) {
    HOSPITAL *n = (HOSPITAL*)malloc(sizeof(HOSPITAL));
    printf("Nombre: "); scanf("%s", n->nombre);
    printf("Dir: "); scanf("%s", n->direccion);
    if (!L->head) { L->head = n; n->siguiente = n; }
    else { HOSPITAL *a = L->head; while(a->siguiente != L->head) a = a->siguiente; a->siguiente = n; n->siguiente = L->head; }
    L->tam++;
}
