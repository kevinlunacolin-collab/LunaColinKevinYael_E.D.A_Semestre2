//En esta parte se encuentran las funciones que nos ayudaran al llenado de infromacion de cada una de las estructuras. 
void llenado_Hospital(HOSPITAL *hospital1){
    char nombre[30];
    char direccion[40];
    printf("\n\n\tBuen dia, por favor ingrese el nombre del hospital: ");
    scanf (" %s", nombre);
    printf("\n\n\tAhora ingrese la direccion del hospital: ");
    scanf (" %s", direccion);

    strcpy(hospital1->nombre, nombre);
    strcpy(hospital1->direccion, direccion);
}

void llenado_Equipo(EQUIPO_MEDICO *equipo1){
    char nombre [30];
    char marca [30];
    char modelo [30];
    printf("\n\n\tAhora porfavor llene los datos del equipo usado por el hospital: ");
    printf("\n\n\tNombre del equipo: ");
    scanf("%s", nombre);
    printf("\n\n\tMarca del equipo: ");
    scanf("%s", marca);  
    printf("\n\n\tModelo del equipo: ");
    scanf(" %s", modelo);

    strcpy(equipo1->nombre, nombre);
    strcpy(equipo1->marca, marca);
    strcpy(equipo1->modelo, modelo);
}

void llenado_especialidad(ESPECIALIDAD *especialidad1, EQUIPO_MEDICO equipo1){
    char nombre [30];
    int cantidad_MATASANOS;
    int cantidad_victimas;
    printf("\n\n\t Especialidad");
    scanf(" %s", nombre); 
    printf("\n\n\tCantidad de doctores en esta especialidad: ");
    scanf("%d", &cantidad_MATASANOS); 
    printf("\n\n\tCantidad de paciente en esta especialidad: ");
    scanf("%d", &cantidad_victimas);

    strcpy(especialidad1->nombre, nombre);
    especialidad1->cantidad_MATASANOS = cantidad_MATASANOS;
    especialidad1->cantidad_victimas = cantidad_victimas;
    especialidad1->equipo = equipo1;
}

void llenado_doctor(DOCTOR *doc1, ESPECIALIDAD *especialidad1){
    char nombre [30];
    int edad;
    int numero_Trabajador;
    int cantidad_pacientes;
    printf("\n\n\tEscriba el nombre del doctor: ");
    scanf( " %s", nombre);
    printf("\n\n\tEscriba la edad del doctor: ");
    scanf("%d", &edad);
    printf("\n\n\tEscriba la cantidad de pacientes que atiende el doctor");
    scanf("%d", &cantidad_pacientes);
    printf("\n\n\tEscriba el numero de trabajador del doctor: ");
    scanf("%d", &numero_Trabajador);

    strcpy(doc1->nombre, nombre);
    doc1->edad = edad;
    doc1->numero_Trabajador = numero_Trabajador;
    doc1->cantidad_pacientes = cantidad_pacientes;
    doc1->especialidad = *especialidad1;
}

void llenado_paciente(PACIENTE *paciente1, HOSPITAL *hospital1, DOCTOR *doc1, ESPECIALIDAD *especialidad1){
    char nombre [30];
    int edad;
    int num_paciente;
    printf("\n\n\tEscriba el nombre del paciente: ");
    scanf(" %s", nombre);
    printf("\n\n\tEscriba la edad del paciente: ");
    scanf("%d", &edad);
    printf("\n\n\tEscriba el numero de paciente: ");
    scanf("%d", &num_paciente);

    strcpy(paciente1->nombre, nombre);
    paciente1->edad = edad;
    paciente1->num_paciente = num_paciente;
    paciente1->hospital = *hospital1;
    paciente1->doc = *doc1;
    paciente1->especial = *especialidad1;
}

void llenado_trabajador(TRABAJADOR *trabajador1){
    int num_trabajador;
    char sindicalizado[2];

    printf("\n\n\tEscriba el numero del trabajador: ");
    scanf("%d", num_trabajador);
    printf("\n\n\tEscriba si el trabajador esta sindicalizado o no (si/no): ");
    scanf(" %s", sindicalizado); 

    if (strcmp(sindicalizado, "si") == 0 || strcmp(sindicalizado, "SI") == 0) {
        strcpy(trabajador1->sindicalizado, "si");
    } else {
        strcpy(trabajador1->sindicalizado, "no");
    }
}

void llenado_intendencia(INTENDENCIA *intendencia1){
    char nombre[30];
    int edad;
    int numero_trabajador;

    printf("\n\n\t Ingrese el nombre: ");
    scanf(" %s", nombre);
    printf("\n\n\t Ingrese la edad: ");
    scanf("%d",edad);
    scanf("%d", numero_trabajador);   
    strcpy(intendencia1->nombre, nombre);
}
