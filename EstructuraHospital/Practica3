/*Este programa va a crear 7 estructuras que guarden datos de un hospital
entradas: Hospital, doctores (especialidad, nombre, edad), medicamentos, pacientes, trabajadores, intendencia
equipo medico
salidas: agregar datos, cambiar datos
restricciones: valores enteros unicamente*/

#include <stdio.h>  
#include <string.h>

// En esta parte definimos las 7 estructuras que se van a usar a lo largo del programa.
/* Cada estructura se hizo con una jerarquia, esto sirve para llamarlas dentro de  las otras estructuras;por ejemplo, en la estrucura de paciente se llaman a las estructuras de Hospital
Especialidad y doctor, por lo que se tuvieron que definir antes de la estrucutra de paciente*/

//Esta estructura guarda los datos del hospital; como el nombre y la dirección del mismo
typedef struct HOSPITAL{
    char nombre[30];
    char direccion[40];
}HOSPITAL;

//Esta estructura guarda los datos del equipo medico del hospital , como el nombre, marca y modelo del equipo medio en uso. 
typedef struct EQUIPO_MEDICO{
    char nombre [30];
    char marca[30];
    char modelo[30];
}EQUIPO_MEDICO;

// Esta estructura guarda los datos de la especialidad de los doctores del hospital, osea, guarda la cantidad de doctores y pacientes. Ademas de guardar el equipo medico que se usa
typedef struct ESPECIALIDAD{
    char nombre [30];
    int cantidad_MATASANOS;// sirve para definir la cantidad de doctores en la especialidad
    int cantidad_victimas;// sirve para definir la cantidad de pacientes en la especialidad 
    EQUIPO_MEDICO equipo; //Aqui se llama a la estructura anterior, por eso es importante que la definieramos antes de esta estructura.
}ESPECIALIDAD;

//Esta estructura guarda los datos de los doctores del hospital. 
typedef struct DOCTOR{
    char nombre[30];
    int edad;
    int numero_Trabajador;
    ESPECIALIDAD especialidad;//Aqui tambien se llama a una estructura anterior. 
    int cantidad_pacientes;
}DOCTOR;

//Aqui se guardan los datos de los pacientes, como sus nombres, edades y su número de paciente
typedef struct PACIENTE{
    char nombre [30];
    int edad;
    int num_paciente;
    HOSPITAL hospital;//En esta parte se llaman a 3 estructuras anteriores. 
    DOCTOR doc;      // Y algo que no mencione es que se tiene que cambiar el nombre de la estructura para poder cambiar sus datos dentro del programa,
    ESPECIALIDAD especial;
}PACIENTE;

//Aqui se guardan los datos de los trabajadores del hospital. 
typedef struct  TRABAJADOR{
    int num_trabajador;
    char sindicalizado [2];
}TRABAJADOR;

//Aqui se guardan los datos de la intendencia del hospital. 
typedef struct INTENDENCIA{
    char nombre [30];
    int edad;
    int num_trabajador;
}INTENDENCIA;

void llenado_Hospital (HOSPITAL *hospital);
void llenado_Equipo(EQUIPO_MEDICO *equipo);
void llenado_especialidad(ESPECIALIDAD *especialidad, EQUIPO_MEDICO equipo);
void llenado_doctor(DOCTOR *doc, ESPECIALIDAD *especialidad);
void llenado_paciente(PACIENTE *paciente , HOSPITAL *hospital, DOCTOR *doc, ESPECIALIDAD *especialidad);
void llenado_trabajador(TRABAJADOR *trabajador);
void llenado_intendencia(INTENDENCIA *intendencia);


